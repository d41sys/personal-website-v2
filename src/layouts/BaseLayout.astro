---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const quotesRaw = await getCollection('quotes');
const quotesJson = JSON.stringify(quotesRaw.map(q => q.data));
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site)} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@d41sy___" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site)} />

    <!-- Computer Modern (LaTeX) web font -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/dreampulse/computer-modern-web-font@master/src/cmu-serif.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Title -->
    <title>{title}</title>

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Tien-Dat Le",
        "alternateName": "Lê Tiến Đạt",
        "jobTitle": "EngD Researcher",
        "affiliation": {
          "@type": "Organization",
          "name": "Eindhoven University of Technology",
          "url": "https://www.tue.nl"
        },
        "url": "https://d41sy.com",
        "email": "tiendatt.716@gmail.com",
        "sameAs": [
          "https://github.com/d41sys",
          "https://www.linkedin.com/in/tien-datle716",
          "https://x.com/d41sy___",
          "https://scholar.google.com/citations?user=JU4RyPQAAAAJ&hl=en"
        ]
      }
    </script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-LPGDL3V5YP"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-LPGDL3V5YP');
    </script>

    <!-- Theme init: inline script to prevent FOUC -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme = stored || 'light';
        document.documentElement.setAttribute('data-theme', theme);
        // Prevent browser from restoring scroll position on reload
        if (history.scrollRestoration) history.scrollRestoration = 'manual';
      })();
    </script>

    <Analytics />

    <!-- Twemoji: cross-platform emoji rendering (fixes flags on Windows) -->
    <script src="https://cdn.jsdelivr.net/npm/twemoji@latest/dist/twemoji.min.js" crossorigin="anonymous"></script>
  </head>
  <body>
    <!-- Full-screen loading overlay -->
    <div id="page-loader" aria-hidden="true">
      <div class="loader-center">
        <span class="loader-monogram">TDL</span>
        <div class="loader-bar"><div class="loader-fill"></div></div>
        <div class="loader-quote">
          <p class="loader-quote-text"></p>
          <p class="loader-quote-attr"></p>
        </div>
      </div>
    </div>

    <!-- Custom cursor glow dot -->
    <div id="cursor-dot" aria-hidden="true"></div>
    <slot />

    <!-- Set --nav-h so hero section can fill exactly the remaining viewport -->
    <script is:inline>
      (function () {
        function setNavH() {
          var h = document.getElementById('site-header');
          if (h) document.documentElement.style.setProperty('--nav-h', h.offsetHeight + 'px');
        }
        setNavH();
        window.addEventListener('resize', setNavH);
      })();
    </script>

    <script is:inline set:html={`window.__QUOTES__=${quotesJson};`}></script>
    <!-- Parse emoji after page load so Twemoji replaces flag glyphs with <img> -->
    <script is:inline>
      window.addEventListener('load', function () {
        if (typeof twemoji !== 'undefined') {
          twemoji.parse(document.body, { folder: 'svg', ext: '.svg' });
        }
      });
    </script>
    <script src="../scripts/cursor.ts"></script>
    <script is:inline>
      (function () {
        var QUOTES = window.__QUOTES__ || [];

        var monogram  = document.querySelector('.loader-monogram');
        var bar       = document.querySelector('.loader-bar');
        var quoteWrap = document.querySelector('.loader-quote');
        var quoteText = document.querySelector('.loader-quote-text');
        var quoteAttr = document.querySelector('.loader-quote-attr');
        if (!monogram) return;

        // Pre-populate so layout is stable before animations begin
        var q = QUOTES[Math.floor(Math.random() * QUOTES.length)] || {};
        if (quoteText) quoteText.textContent = '\u201c' + (q.text || '') + '\u201d';
        if (quoteAttr) quoteAttr.textContent = q.attr || '';

        var POOL = 'abcdeghjkmnpqrstuvwxyz23456789';

        function scramble(el, target, duration, cb) {
          var tick    = 40;
          var start   = Date.now();
          var fromLen = el.textContent.length;
          var toLen   = target.length;
          var chars   = target.split('');
          var timer   = setInterval(function () {
            var p          = Math.min((Date.now() - start) / duration, 1);
            var visibleLen = Math.round(fromLen + (toLen - fromLen) * p);
            var out        = '';
            for (var i = 0; i < visibleLen; i++) {
              var ch = chars[i];
              if (!/[A-Za-z]/.test(ch)) { out += ch; continue; }
              out += p >= (i + 1) / toLen
                ? ch
                : POOL[Math.floor(Math.random() * POOL.length)];
            }
            el.textContent = out;
            if (p >= 1) { el.textContent = target; clearInterval(timer); if (cb) cb(); }
          }, tick);
        }

        var seqDone = false, pageLoaded = false;
        function tryExit() {
          if (!seqDone || !pageLoaded) return;
          var el = document.getElementById('page-loader');
          if (!el) return;
          var center = el.querySelector('.loader-center');
          if (center) center.classList.add('exit');
          setTimeout(function () {
            el.classList.add('loader-open');
            setTimeout(function () { el.remove(); }, 620);
          }, 300);
        }

        window.addEventListener('load', function () { pageLoaded = true; tryExit(); });

        // Noise phase: random chars cycle before resolving to 'd41sy'
        var noiseLen = 5;
        function randomNoise() {
          var s = '';
          for (var n = 0; n < noiseLen; n++) s += POOL[Math.floor(Math.random() * POOL.length)];
          return s;
        }
        monogram.textContent = randomNoise();
        var noiseEnd   = Date.now() + 500;
        var noiseTimer = setInterval(function () {
          monogram.textContent = randomNoise();
          if (Date.now() >= noiseEnd) {
            clearInterval(noiseTimer);
            scramble(monogram, 'd41sy', 600, function () {
              setTimeout(function () {
                scramble(monogram, 'hello world!', 600, function () {
                  if (bar) { bar.style.opacity = '0'; bar.style.transform = 'translateY(-4px)'; }
                  if (quoteWrap) quoteWrap.classList.add('visible');
                  setTimeout(function () { seqDone = true; tryExit(); }, 2000);
                });
              }, 200);
            });
          }
        }, 40);
      })();
    </script>
    <SpeedInsights />
  </body>
</html>
