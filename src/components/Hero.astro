---
import { getCollection } from 'astro:content';
import { Icon } from "astro-icon/components";
import { formatText } from '../utils/format';

const allSocial = await getCollection('social');
const socialLinks = allSocial.map(e => e.data);

const allHero = await getCollection('hero');
const h = allHero[0].data;
---

<section id="top" style="padding: 4rem 0 3rem; border-top: none; display: flex; flex-direction: column; justify-content: center;">
  <div class="container">
    <div class="hero-grid">
      <!-- Left: profile photo -->
      <div data-reveal class="hero-photo-col" style="flex-shrink: 0; display: flex;">
        <div class="photo-status-wrap">
          <div class="photo-container">
            <img
              class="photo-layer photo-layer-a"
              src="/profile.jpg"
              alt={h.name}
              width="256"
              height="320"
            />
            <img
              class="photo-layer photo-layer-b"
              src="/profile0.jpg"
              alt={h.name}
              width="256"
              height="320"
            />
            <div
              class="photo-placeholder"
              style="display:none;flex-direction:column;align-items:center;justify-content:center;width:100%;height:100%;gap:0.25rem;"
            >
              <span
                style="font-family:var(--font-mono);font-size:1.5rem;font-weight:700;opacity:0.15;"
                >TDL</span
              >
              <span
                style="font-family:var(--font-mono);font-size:0.6rem;opacity:0.35;text-align:center;padding:0 0.5rem;"
                >add profile.jpg<br />to public/</span
              >
            </div>
          </div>
          {h.status && (
            <div class="photo-status-badge" aria-label={h.status}>
              <span class="status-dot" aria-hidden="true"></span>
              <div class="status-ticker" aria-hidden="true">
                <span class="status-track">
                  {h.status}&nbsp;&nbsp;·&nbsp;&nbsp;{h.status}&nbsp;&nbsp;·&nbsp;&nbsp;
                </span>
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Right: text content -->
      <div>
        <!-- Name -->
        <div data-reveal>
          <h1 style="margin-bottom: 0.5rem;">{h.name}</h1>
        </div>

        <!-- Role + flag -->
        <div data-reveal style="margin-bottom: 1rem;">
          <p
            style="font-size: 0.95rem; color: var(--color-muted); font-weight: 400; margin-bottom: 0.25rem;"
          >
            {h.flag} {h.role} · {h.institution}
          </p>
          <p
            style="font-size: 1rem; font-weight: 500; line-height: 1.5; max-width: 36rem;"
            set:html={formatText(h.tagline)}
          />
        </div>

        <!-- Story / narrative arc -->
        <div data-reveal style="margin-bottom: 1.75rem;">
          <p
            style="font-size: 0.9rem; color: var(--color-muted); max-width: 40rem; line-height: 1.75; margin: 0;"
            set:html={formatText(h.bio)}
          />
        </div>

        <!-- Social links -->
        <div data-reveal class="hero-social" style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                target={link.href.startsWith("mailto") ? "_self" : "_blank"}
                rel="noopener noreferrer"
                aria-label={link.label}
                title={link.label}
                class="hero-social-link"
              >
                <Icon name={link.icon} width={13} height={13} />
                <span class="hero-btn-label">{link.label}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero-social-link {
  position: relative;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 400;
  opacity: 0.6;
  border: 1px solid var(--color-border);
  padding: 0.3rem 0.6rem;
  transition: opacity 0.2s, color 0.2s, border-color 0.15s;
}

/* ── Moving border trace (desktop only) ─────────────────── */
@media (min-width: 641px) {
  .hero-social-link::before,
  .hero-social-link::after {
    content: '';
    position: absolute;
    top: -1px;
    left: -1px;
  }

  /* Phase 1: top + bottom borders grow left→right */
  .hero-social-link::before {
    width: 0;
    height: calc(100% + 2px);
    border-top: 1px solid var(--color-accent);
    border-bottom: 1px solid var(--color-accent);
    transition: width 0.12s ease-out 0s;
  }

  /* Phase 2: left + right borders grow top→bottom */
  .hero-social-link::after {
    width: calc(100% + 2px);
    height: 0;
    border-left: 1px solid var(--color-accent);
    border-right: 1px solid var(--color-accent);
    transition: height 0.12s ease-out 0.1s;
  }

  .hero-social-link:hover {
    opacity: 1;
    color: var(--color-accent);
    border-color: transparent;
  }

  .hero-social-link:hover::before {
    width: calc(100% + 2px);
  }

  .hero-social-link:hover::after {
    height: calc(100% + 2px);
  }
}

/* ── Profile photo status ───────────────────────────────── */
.photo-status-wrap {
  position: relative;
  width: 16rem;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.photo-container {
  flex: 1;
  min-height: 9rem;
  overflow: hidden;
  border: 2px solid var(--color-accent);
  background-color: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: photo-border-breathe 3s ease-in-out infinite;
  position: relative;
}

.photo-layer {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transform-origin: center center;
  will-change: transform, opacity, filter;
}

/* Photo A sits on top; photo B underneath */
.photo-layer-a { z-index: 2; animation: photo-blend-a 12s ease-in-out infinite; }
.photo-layer-b { z-index: 1; animation: photo-blend-b 12s ease-in-out infinite; }

/*
 * Cycle (12 s):
 *   0 – 45 %  → A visible, slowly zooms in (Ken Burns)
 *   45 – 50 % → A blurs + fades out; B fades in clear
 *   50 – 95 % → B visible, slowly zooms in (Ken Burns)
 *   95 – 100% → B blurs + fades out; A fades back in
 */
@keyframes photo-blend-a {
  0%       { opacity: 1; transform: scale(1);    filter: blur(0px) brightness(1); }
  45%      { opacity: 1; transform: scale(1.07); filter: blur(0px) brightness(1); }
  50%      { opacity: 0; transform: scale(1.09); filter: blur(10px) brightness(1.15); }
  50.01%   { opacity: 0; transform: scale(1);    filter: blur(0px) brightness(1); }
  95%      { opacity: 0; transform: scale(1);    filter: blur(0px) brightness(1); }
  100%     { opacity: 1; transform: scale(1);    filter: blur(0px) brightness(1); }
}

@keyframes photo-blend-b {
  0%       { opacity: 0; transform: scale(1);    filter: blur(0px) brightness(1); }
  50%      { opacity: 0; transform: scale(1);    filter: blur(0px) brightness(1); }
  55%      { opacity: 1; transform: scale(1);    filter: blur(0px) brightness(1); }
  95%      { opacity: 1; transform: scale(1.07); filter: blur(0px) brightness(1); }
  100%     { opacity: 0; transform: scale(1.09); filter: blur(10px) brightness(1.15); }
}

@media (prefers-reduced-motion: reduce) {
  .photo-layer-a { opacity: 1; transform: none; filter: none; animation: none; }
  .photo-layer-b { opacity: 0; animation: none; }
}

@keyframes photo-border-breathe {
  0%, 100% { border-color: var(--color-accent); }
  50%       { border-color: color-mix(in srgb, var(--color-accent) 35%, transparent); }
}

.photo-status-badge {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 500;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  background-color: var(--color-accent);
  color: #fff;
  padding: 0.22rem 0.4rem;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 0.3rem;
  overflow: hidden;
}
[data-theme="dark"] .photo-status-badge { color: #161618; }

.status-dot {
  display: inline-block;
  width: 5px;
  height: 5px;
  background-color: currentColor;
  flex-shrink: 0;
  animation: status-blink 1.4s step-end infinite;
}
@keyframes status-blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}

/* Marquee ticker */
.status-ticker {
  overflow: hidden;
  flex: 1;
  min-width: 0;
}
.status-track {
  display: inline-block;
  white-space: nowrap;
  animation: ticker-scroll 9s linear infinite;
}
@keyframes ticker-scroll {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
@media (prefers-reduced-motion: reduce) {
  .status-track { animation: none; }
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 3rem;
  align-items: stretch;
}

  @media (min-width: 641px) and (max-width: 900px) {
    #top {
      padding: 3rem 0 2.5rem !important;
      min-height: calc(100dvh - var(--nav-h, 3.25rem));
      display: flex !important;
      flex-direction: column;
      justify-content: center;
    }
    .hero-grid {
      gap: 2rem;
      align-items: start;
    }
    .photo-status-wrap {
      width: 11rem;
      height: auto;
    }
    .photo-container {
      aspect-ratio: 4 / 5;
      min-height: unset;
      flex: none;
    }
  }

  @media (max-width: 640px) {
    #top {
      padding: 2rem 0 !important;
      min-height: calc(100dvh - var(--nav-h, 3.25rem));
      display: flex !important;
      flex-direction: column;
      justify-content: center;
    }
    #top .container {
      width: 100%;
    }
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    /* Hide photo on mobile */
    .hero-photo-col {
      display: none !important;
    }
    /* Icons only on mobile */
    .hero-btn-label {
      display: none;
    }
    /* Center buttons on mobile */
    .hero-social {
      justify-content: center;
    }
  }
</style>
