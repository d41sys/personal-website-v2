<button
  id="back-to-top"
  aria-label="Back to top"
  class="back-to-top"
>
  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
    <path d="M7 12V2M2 7l5-5 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

<style>
  .back-to-top {
    position: fixed;
    bottom: 1.75rem;
    right: 1.75rem;
    z-index: 90;

    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;

    background: var(--color-bg);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    cursor: pointer;

    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease, background-color 0.18s, color 0.18s, border-color 0.18s;
  }

  .back-to-top.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .back-to-top:hover {
    background-color: var(--color-accent);
    color: #fff;
  }

  [data-theme="dark"] .back-to-top:hover {
    color: #161618;
  }

  .back-to-top:active {
    transform: translateY(1px) scale(0.95);
  }

  @media (max-width: 640px) {
    .back-to-top {
      bottom: 1.25rem;
      right: 1.1rem;
    }
  }

  @media (hover: none) {
    .back-to-top:hover {
      background-color: var(--color-bg) !important;
      color: var(--color-accent) !important;
    }
  }
</style>

<script>
  const btn = document.getElementById('back-to-top');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 320) {
      btn?.classList.add('is-visible');
    } else {
      btn?.classList.remove('is-visible');
    }
  }, { passive: true });

  btn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
