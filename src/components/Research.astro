---
import { getCollection } from 'astro:content';
import SectionHeading from './SectionHeading.astro';
import { formatText } from '../utils/format';

const allInterests = await getCollection('research-interests');
const interests = allInterests
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .map(e => e.data.label);

const allIntro = await getCollection('research-intro');
const { paragraphs } = allIntro[0].data;
---

<section id="research">
  <div class="container">
    <SectionHeading title="Research" />

    <div data-reveal>
      {paragraphs.map((p, i) => (
        <p
          style={`line-height: 1.8;${p.muted ? ' color: var(--color-muted); font-size: 0.95rem;' : ''}${i < paragraphs.length - 1 ? ' margin-bottom: 1.25rem;' : ''}`}
          set:html={formatText(p.text)}
        />
      ))}
    </div>

    <!-- Research interests tags -->
    <div data-reveal style="margin-top: 1.75rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
      {interests.map(label => (
        <span class="tag">{label}</span>
      ))}
    </div>
  </div>
</section>
