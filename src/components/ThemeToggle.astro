---
import { Icon } from 'astro-icon/components';
---

<button
  id="theme-toggle"
  class="theme-toggle-btn"
  aria-label="Toggle dark/light theme"
  title="Toggle theme"
>
  <span id="theme-icon-wrap" class="theme-icon-wrap">
    <span id="theme-icon-sun" style="display:none;" aria-hidden="true">
      <Icon name="lucide:sun" width={17} height={17} />
    </span>
    <span id="theme-icon-moon" aria-hidden="true">
      <Icon name="lucide:moon" width={17} height={17} />
    </span>
  </span>
</button>

<style>
  .theme-toggle-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    color: inherit;
    opacity: 0.65;
    transition: opacity 0.2s;
  }

  .theme-toggle-btn:hover { opacity: 1; }

  .theme-icon-wrap {
    display: flex;
    align-items: center;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .theme-toggle-btn:hover .theme-icon-wrap {
    transform: rotate(22deg) scale(1.18);
  }

  @keyframes theme-spin {
    0%   { transform: rotate(0deg)   scale(1);    }
    40%  { transform: rotate(200deg) scale(0.78); }
    100% { transform: rotate(360deg) scale(1);    }
  }

  .theme-icon-wrap.spinning {
    animation: theme-spin 0.42s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
</style>

<script src="../scripts/theme.ts"></script>
