---
import { getCollection } from 'astro:content';
import SectionHeading from './SectionHeading.astro';

const allEducation = await getCollection('education');
const education = allEducation
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .map(e => e.data);
---

<section id="education">
  <div class="container">
    <SectionHeading title="Education" />

    <div class="tl-wrap">
      {education.map((edu, i) => (
        <div data-reveal class={`tl-row${edu.current ? ' tl-current' : ''}`}>
          <div class="tl-gutter">
            <div class="tl-dot"></div>
            <div class="tl-line"></div>
          </div>
          <div class="tl-body">
            <!-- Period + location -->
            <div class="meta" style="margin-bottom: 0.2rem;">
              {edu.period} · {edu.flag} {edu.location}
            </div>

            <!-- Degree + abbrev badge -->
            <div style="display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.15rem;">
              <span style="font-weight: 600; font-size: 0.92rem; line-height: 1.35;">{edu.degree}</span>
              <span class="tag" style="font-size: 0.6rem;">{edu.abbrev}</span>
            </div>

            <!-- Institution -->
            <div style="font-size: 0.85rem; color: var(--color-muted); margin-bottom: 0.4rem;">
              {edu.institution}
            </div>

            {edu.gpa && (
              <div class="meta" style="margin-bottom: 0.15rem;">GPA: {edu.gpa}</div>
            )}
            {edu.thesis && (
              <div class="meta" style="margin-bottom: 0.15rem; font-style: italic;">
                Thesis: "{edu.thesis}"
              </div>
            )}
            {edu.note && (
              <div style="font-size: 0.82rem; color: var(--color-muted); margin-bottom: 0.15rem;">
                {edu.note}
              </div>
            )}
            {edu.award && (
              <div style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--color-accent); margin-top: 0.25rem;">
                ★ {edu.award}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
