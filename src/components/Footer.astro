---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();
const allSocial = await getCollection('social');
const socialLinks = allSocial.map(e => e.data);
---

<footer style="padding: 3rem 0 2rem;">
  <div class="container">
    <!-- Top row: name + tagline + year -->
    <div style="
      text-align: center;
      margin-bottom: 1.75rem;
    ">
      
      <div class="meta" style="margin-top:0.35rem;">© {year}</div>
    </div>

    <!-- Social icons + links -->
    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center; justify-content: center;">
      {socialLinks.map(link => (
        <a
          href={link.href}
          target={link.href.startsWith('mailto') ? '_self' : '_blank'}
          rel="noopener noreferrer"
          aria-label={link.label}
          title={link.label}
          class="footer-social-link"
        >
          <Icon name={link.icon} width={14} height={14} />
          <span class="footer-link-label">{link.label}</span>
        </a>
      ))}
    </div>
  </div>
</footer>

<style>
  .footer-social-link {
    display: flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 300;
    opacity: 0.55;
    transition: opacity 0.2s, color 0.2s;
  }

  .footer-social-link:hover {
    opacity: 1;
    color: var(--color-accent);
  }

  /* Desktop: icon only by default, reveal label on hover */
  @media (min-width: 641px) {
    .footer-link-label {
      max-width: 0;
      overflow: hidden;
      white-space: nowrap;
      padding-left: 0;
      opacity: 0;
      transition:
        max-width 0.3s cubic-bezier(0.4, 0, 0.2, 1),
        padding-left 0.3s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.2s ease;
    }

    .footer-social-link:hover .footer-link-label {
      max-width: 6rem;
      padding-left: 0.35rem;
      opacity: 1;
    }
  }

  /* Mobile: hide labels entirely */
  @media (max-width: 640px) {
    .footer-link-label { display: none; }
  }
</style>
