---
import { getCollection } from 'astro:content';
import SectionHeading from './SectionHeading.astro';
import { byDateDesc } from '../utils/date';

const allHonors = await getCollection('honors');
const honors = allHonors.map(e => e.data).sort(byDateDesc);
---

<section id="honors">
  <div class="container">
    <SectionHeading title="Honors & Awards" />

    <div>
      {honors.map(h => (
        <div data-reveal class="flat-row honor-row">
          <span class="honor-title">{h.award}</span>
          <span class="honor-sep"> · </span>
          <span class="meta honor-org">{h.org}</span>
          <span class="meta honor-date">{h.date}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .honor-row {
    justify-content: flex-start;
    gap: 0;
  }
  .honor-title {
    font-size: 0.9rem;
    font-weight: 500;
  }
  .honor-sep {
    color: var(--color-muted);
    padding: 0 0.05rem;
  }
  .honor-date {
    margin-left: auto;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .honor-title {
      flex-basis: 100%;
    }
    .honor-sep {
      display: none;
    }
  }
</style>
