---
import SectionHeading from './SectionHeading.astro';

const honors = [
  {
    award: '3rd Place — LISATHON (LISA Lab Hackathon)',
    date: 'Dec 2024',
    org: 'Soonchunhyang University',
  },
  {
    award: 'Top Highest GPA — Computer Network Faculty',
    date: 'Aug 2021',
    org: 'HCMUS, Vietnam National University',
  },
  {
    award: 'TOP 7 — HCMUS-CTF Final (Capture the Flag)',
    date: 'May 2020',
    org: 'HCMUS, Vietnam National University',
  },
  {
    award: 'MCSA Certification Scholarship for Excellent Students',
    date: 'Jan 2020',
    org: 'SaigonCTT',
  },
];
---

<section id="honors">
  <div class="container">
    <SectionHeading title="Honors & Awards" />

    <div>
      {honors.map(h => (
        <div data-reveal class="flat-row honor-row">
          <span class="honor-title">{h.award}</span>
          <span class="honor-sep"> · </span>
          <span class="meta honor-org">{h.org}</span>
          <span class="meta honor-date">{h.date}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .honor-row {
    justify-content: flex-start;
    gap: 0;
  }
  .honor-title {
    font-size: 0.9rem;
    font-weight: 500;
  }
  .honor-sep {
    color: var(--color-muted);
    padding: 0 0.05rem;
  }
  .honor-date {
    margin-left: auto;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .honor-title {
      flex-basis: 100%;
    }
    .honor-sep {
      display: none;
    }
  }
</style>
